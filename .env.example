# Microsoft Foundry - Phi-4-mini-instruct
FOUNDRY_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>/openai/v1
FOUNDRY_MODEL_DEPLOYMENT=Phi-4-mini-instruct
FOUNDRY_API_KEY=

# Foundry IQ - grounded knowledge (Microsoft IQ layer)
FOUNDRY_IQ_PROJECT_ENDPOINT=
FOUNDRY_IQ_KNOWLEDGE_BASE=
FOUNDRY_IQ_API_KEY=

# Knowledge backend: local (offline seed corpus) or foundry_iq
KNOWLEDGE_BACKEND=local
