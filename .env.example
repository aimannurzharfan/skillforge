# Microsoft Foundry - Phi-4-mini-instruct (OpenAI-compatible endpoint)
FOUNDRY_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>/openai/v1
FOUNDRY_MODEL_DEPLOYMENT=Phi-4-mini-instruct
FOUNDRY_API_KEY=

# Foundry IQ - grounded knowledge (Azure AI Search knowledge base)
FOUNDRY_IQ_PROJECT_ENDPOINT=
FOUNDRY_IQ_KNOWLEDGE_BASE=skillforge-network
FOUNDRY_IQ_API_KEY=
# The Azure AI Search service that backs the knowledge base, e.g.
# https://<search-service>.search.windows.net  (find it under the project's
# CognitiveSearch connection). Required only for the foundry_iq backend.
FOUNDRY_IQ_SEARCH_ENDPOINT=
# Auth for the retrieve action: set a Search query/admin key here, OR leave it
# blank to use Entra ID (needs the Search Index Data Reader role on the service).
FOUNDRY_IQ_SEARCH_KEY=
# GA extractive retrieve api-version (no LLM, no answer synthesis).
FOUNDRY_IQ_API_VERSION=2026-04-01

# Knowledge backend: local (offline seed corpus, default) or foundry_iq
KNOWLEDGE_BACKEND=local
